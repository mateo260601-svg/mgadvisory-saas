# MG Advisory Finance OS — Local environment template
# Copy to .env for local development. Never commit .env to git.

# ---- Required (change before production) ----
MG_LICENSE_KEY=MG-ADVISORY-DEMO-2026
APP_SECRET=replace-with-a-long-random-secret-before-production

# ---- Google OAuth (optional — app works without these) ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
# Leave empty to allow any Google account, or restrict to domains:
GOOGLE_ALLOWED_DOMAINS=

# ---- Claude AI (optional — app uses local fallbacks without this) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
